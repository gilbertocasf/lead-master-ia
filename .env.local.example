# Supabase — credenciais do projeto
# Copie este arquivo para .env.local e preencha com os valores do seu projeto.
# Encontre-os em: Supabase → Project Settings → Data API / API Keys.
#
# Sem estas variáveis, o sistema continua funcionando com dados de exemplo (mock).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Service Role Key — usado apenas pelo servidor (API routes).
# Nunca usar com prefixo NEXT_PUBLIC_. Encontre em: Supabase → Project Settings → API Keys.
SUPABASE_SERVICE_ROLE_KEY=

# E-mail — notificação ao corretor via Resend (https://resend.com)
# RESEND_API_KEY: chave de API do Resend. Nunca usar NEXT_PUBLIC_.
# EMAIL_FROM: remetente no formato "Nome <email@dominio.com>"
#
# Sem estas variáveis, o sistema funciona normalmente mas não envia e-mails.
RESEND_API_KEY=
EMAIL_FROM=
